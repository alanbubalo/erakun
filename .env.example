APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

FISCALIZATION_SERVICE_URL=http://localhost:8001
FISCALIZATION_SERVICE_TIMEOUT=10

AS4_TIMEOUT=15
AS4_DEFAULT_PEER_URL=http://localhost:8002
# Per-OIB peer overrides, comma-separated "oib=url" pairs.
AS4_PEER_MAP=

# Discovery (Phase 6). AMS = central locator at Porezna uprava (erakun-porezna).
AMS_BASE_URL=http://localhost:8001
# MPS = the metadata service we publish for our own taxpayers.
MPS_BASE_URL=http://localhost:8000
MPS_AS4_ENDPOINT=http://localhost:8000/api/as4/inbox

# Test PKI. Self-generated CAs stand in for FINA (party signing certs) and
# OpenPEPPOL (access point cert). Run `php artisan pki:generate` to mint them;
# private keys live on the gitignored `pki` disk (storage/app/private/pki).
PKI_DISK=pki
PKI_FINA_CN="eRakun Test FINA CA"
PKI_PEPPOL_CN="eRakun Test PEPPOL CA"
PKI_AP_CN="eRakun Test Access Point"
